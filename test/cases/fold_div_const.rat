@name fold: sdiv of constants (20/4 = 5)
@passes fold

@input
func t(i32) -> i32 {
	v0 = start : (ctrl, mem, i32)
	v1 = stop : ctrl v7
	v2 = proj : ctrl  #0 "ctrl" of v0
	v3 = proj : mem  #1 "mem" of v0
	v4 = const : i32  4
	v5 = const : i32  20
	v6 = sdiv : i32 v5, v4
	v7 = return : ctrl v2, v3, v6
}

@expect
func t(i32) -> i32 {
	v0 = start : (ctrl, mem, i32)
	v1 = stop : ctrl v7
	v2 = proj : ctrl  #0 "ctrl" of v0
	v3 = proj : mem  #1 "mem" of v0
	v7 = return : ctrl v2, v3, v8
	v8 = const : i32  5
}
