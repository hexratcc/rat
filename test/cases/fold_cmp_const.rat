@name fold: slt(2, 3) folds to true
@passes fold

@input
func t(i32) -> i1 {
	v0 = start : (ctrl, mem, i32)
	v1 = stop : ctrl v7
	v2 = proj : ctrl  #0 "ctrl" of v0
	v3 = proj : mem  #1 "mem" of v0
	v4 = const : i32  3
	v5 = const : i32  2
	v6 = slt : i1 v5, v4
	v7 = return : ctrl v2, v3, v6
}

@expect
func t(i32) -> i1 {
	v0 = start : (ctrl, mem, i32)
	v1 = stop : ctrl v7
	v2 = proj : ctrl  #0 "ctrl" of v0
	v3 = proj : mem  #1 "mem" of v0
	v7 = return : ctrl v2, v3, v8
	v8 = const : i1  1
}
