@name parser round-trip: globals, alloc and global-ref survive parse+emit
@passes

@input
const greeting : [2 x i8] = "hi"
var counter : i32 = ""

func t() -> i32 {
	v0 = start : (ctrl, mem)
	v1 = stop : ctrl v8
	v2 = proj : ctrl  #0 "ctrl" of v0
	v3 = proj : mem  #1 "mem" of v0
	v4 = alloc : ptr  i32
	v5 = global : ptr  "counter"
	v6 = const : i32  7
	v7 = store : mem v2, v3, v5, v6
	v8 = return : ctrl v2, v7, v6
}

@expect
const greeting : [2 x i8] = "hi"
var counter : i32 = ""

func t() -> i32 {
	v0 = start : (ctrl, mem)
	v1 = stop : ctrl v8
	v2 = proj : ctrl  #0 "ctrl" of v0
	v3 = proj : mem  #1 "mem" of v0
	v4 = alloc : ptr  i32
	v5 = global : ptr  "counter"
	v6 = const : i32  7
	v7 = store : mem v2, v3, v5, v6
	v8 = return : ctrl v2, v7, v6
}
