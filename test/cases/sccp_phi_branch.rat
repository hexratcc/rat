@name sccp: phi collapses to a constant when one edge is unreachable
@passes sccp

@input
func sccp(i32, i32) -> i32 {
	v0 = start : (ctrl, mem, i32, i32)
	v1 = stop : ctrl v17
	v2 = proj : ctrl  #0 "ctrl" of v0
	v3 = proj : mem  #1 "mem" of v0
	v6 = const : i32  1
	v7 = const : i32  2
	v8 = slt : i1 v6, v7
	v9 = if : (ctrl, ctrl) v2, v8
	v10 = proj : ctrl  #0 "then" of v9
	v11 = proj : ctrl  #1 "else" of v9
	v12 = region : ctrl v11, v10
	v14 = const : i32  20
	v15 = const : i32  10
	v13 = phi : i32 v12, v14, v15
	v17 = return : ctrl v12, v3, v13
}

@expect
func sccp(i32, i32) -> i32 {
	v0 = start : (ctrl, mem, i32, i32)
	v1 = stop : ctrl v10
	v2 = proj : ctrl  #0 "ctrl" of v0
	v3 = proj : mem  #1 "mem" of v0
	v4 = region : ctrl v9, v8
	v5 = const : i1  1
	v6 = const : i32  10
	v7 = if : (ctrl, ctrl) v2, v5
	v8 = proj : ctrl  #0 "then" of v7
	v9 = proj : ctrl  #1 "else" of v7
	v10 = return : ctrl v4, v3, v6
}
