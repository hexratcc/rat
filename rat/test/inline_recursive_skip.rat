@name inline: a self-recursive call is left intact
@passes inline

@input
func two() -> i32 {
	v0 = start : (ctrl, mem)
	v1 = stop : ctrl v5
	v2 = proj : ctrl  #0 "ctrl" of v0
	v3 = proj : mem  #1 "mem" of v0
	v4 = const : i32  2
	v5 = return : ctrl v2, v3, v4
}

func rec(i32) -> i32 {
	v0 = start : (ctrl, mem, i32)
	v1 = stop : ctrl v9
	v2 = proj : ctrl  #0 "ctrl" of v0
	v3 = proj : mem  #1 "mem" of v0
	v4 = proj : i32  #2 "arg0" of v0
	v5 = call : (ctrl, mem, i32) "rec" v2, v3, v4
	v6 = proj : ctrl  #0 "ctrl" of v5
	v7 = proj : mem  #1 "mem" of v5
	v8 = proj : i32  #2 "ret" of v5
	v9 = return : ctrl v6, v7, v8
}

@expect
func two() -> i32 {
	v0 = start : (ctrl, mem)
	v1 = stop : ctrl v5
	v2 = proj : ctrl  #0 "ctrl" of v0
	v3 = proj : mem  #1 "mem" of v0
	v4 = const : i32  2
	v5 = return : ctrl v2, v3, v4
}

func rec(i32) -> i32 {
	v0 = start : (ctrl, mem, i32)
	v1 = stop : ctrl v9
	v2 = proj : ctrl  #0 "ctrl" of v0
	v3 = proj : mem  #1 "mem" of v0
	v4 = proj : i32  #2 "arg0" of v0
	v5 = call : (ctrl, mem, i32) "rec" v2, v3, v4
	v6 = proj : ctrl  #0 "ctrl" of v5
	v7 = proj : mem  #1 "mem" of v5
	v8 = proj : i32  #2 "ret" of v5
	v9 = return : ctrl v6, v7, v8
}
